{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YAN555999/footballproofai-reproducibility-ledger/blob/main/receipt.schema.json",
  "title": "Football Proof AI benchmark reproducibility receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "checkedAt", "producer", "checks"],
  "properties": {
    "schemaVersion": {
      "const": "footballproofai-research-reproducibility/1.0.0"
    },
    "checkedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.000Z$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "workflow", "runId", "runAttempt", "commitSha"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "workflow": { "type": "string", "minLength": 1, "maxLength": 200 },
        "runId": { "type": "string", "pattern": "^[0-9]+$" },
        "runAttempt": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "commitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        { "$ref": "#/$defs/checkScoring" },
        { "$ref": "#/$defs/checkMargin" },
        { "$ref": "#/$defs/checkCalibration" },
        { "$ref": "#/$defs/checkPoissonGrid" },
        { "$ref": "#/$defs/checkDixonColes" }
      ],
      "items": false
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmarkId", "benchmarkVersion", "manifestPath", "manifestSha256",
        "generatorPath", "generatorSha256", "sourceDigestSha256",
        "artifactDigestSha256", "reproduced", "errorSha256"
      ],
      "properties": {
        "benchmarkId": { "type": "string" },
        "benchmarkVersion": { "type": "string" },
        "manifestPath": { "type": "string" },
        "manifestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "generatorPath": { "type": "string" },
        "generatorSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sourceDigestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "artifactDigestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "reproduced": { "type": "boolean" },
        "errorSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "checkScoring": {
      "allOf": [
        { "$ref": "#/$defs/check" },
        { "properties": {
          "benchmarkId": { "const": "football-1x2-scoring-benchmark" },
          "benchmarkVersion": { "const": "football-1x2-empirical-benchmark/1.0.0" },
          "manifestPath": { "const": "data/football-1x2-empirical-benchmark-1.0.0-manifest.json" },
          "generatorPath": { "const": "scripts/generate-football-1x2-empirical-benchmark.mjs" }
        } }
      ]
    },
    "checkMargin": {
      "allOf": [
        { "$ref": "#/$defs/check" },
        { "properties": {
          "benchmarkId": { "const": "football-1x2-margin-removal-benchmark" },
          "benchmarkVersion": { "const": "football-1x2-margin-removal-benchmark/1.0.0" },
          "manifestPath": { "const": "data/football-1x2-margin-removal-benchmark-1.0.0-manifest.json" },
          "generatorPath": { "const": "scripts/generate-football-1x2-margin-removal-benchmark.mjs" }
        } }
      ]
    },
    "checkCalibration": {
      "allOf": [
        { "$ref": "#/$defs/check" },
        { "properties": {
          "benchmarkId": { "const": "football-1x2-probability-calibration-benchmark" },
          "benchmarkVersion": { "const": "football-1x2-probability-calibration-benchmark/1.0.0" },
          "manifestPath": { "const": "data/football-1x2-probability-calibration-benchmark-1.0.0-manifest.json" },
          "generatorPath": { "const": "scripts/generate-football-1x2-probability-calibration-benchmark.mjs" }
        } }
      ]
    },
    "checkPoissonGrid": {
      "allOf": [
        { "$ref": "#/$defs/check" },
        { "properties": {
          "benchmarkId": { "const": "football-poisson-scenario-grid" },
          "benchmarkVersion": { "const": "football-independent-poisson-scenario-grid/1.0.0" },
          "manifestPath": { "const": "data/football-poisson-scenario-grid-1.0.0-manifest.json" },
          "generatorPath": { "const": "scripts/generate-football-poisson-scenario-grid.mjs" }
        } }
      ]
    },
    "checkDixonColes": {
      "allOf": [
        { "$ref": "#/$defs/check" },
        { "properties": {
          "benchmarkId": { "const": "poisson-vs-dixon-coles-football-benchmark" },
          "benchmarkVersion": { "const": "poisson-vs-dixon-coles-football-benchmark/1.0.0" },
          "manifestPath": { "const": "data/poisson-vs-dixon-coles-football-benchmark-1.0.0-manifest.json" },
          "generatorPath": { "const": "scripts/generate-poisson-vs-dixon-coles-benchmark.mjs" }
        } }
      ]
    }
  }
}
